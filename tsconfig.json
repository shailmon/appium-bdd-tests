{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "@wdio/globals/types", "@wdio/cucumber-framework"]
  },
  "include": [
    "features/**/*.ts",
    "step-definitions/**/*.ts",
    "support/**/*.ts",
    "utils/**/*.ts",
    "config/**/*.ts"
  ]
}
